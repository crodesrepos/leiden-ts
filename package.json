{
  "name": "leiden-ts",
  "version": "0.1.0",
  "description": "Pure-TypeScript implementation of the Leiden community-detection algorithm (Traag, Waltman & van Eck, 2019). Zero runtime dependencies. Faster than graspologic across the standard benchmark portfolio.",
  "keywords": [
    "leiden",
    "louvain",
    "community-detection",
    "graph",
    "modularity",
    "clustering",
    "graph-algorithms",
    "knowledge-graph",
    "typescript"
  ],
  "license": "MIT",
  "author": "crodesrepos <crankthesiren@gmail.com>",
  "homepage": "https://github.com/crodesrepos/leiden-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crodesrepos/leiden-ts.git"
  },
  "bugs": {
    "url": "https://github.com/crodesrepos/leiden-ts/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "bench": "tsx bench/modularity.ts && tsx bench/localMove.ts && tsx bench/refine.ts && tsx bench/leiden.ts && tsx bench/cross-validation-report.ts",
    "bench:modularity": "tsx bench/modularity.ts",
    "bench:localMove": "tsx bench/localMove.ts",
    "bench:refine": "tsx bench/refine.ts",
    "bench:leiden": "tsx bench/leiden.ts",
    "bench:parity": "tsx bench/cross-validation-report.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.10"
  },
  "devDependencies": {
    "@types/node": "^22",
    "fast-check": "^3.22",
    "tsup": "^8",
    "tsx": "^4.21.0",
    "typescript": "^6.0",
    "vitest": "^2"
  },
  "publishConfig": {
    "access": "public"
  }
}
